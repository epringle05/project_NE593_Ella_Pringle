import torch
import torch.nn as nn
import torch.nn.functional as F
import numpy as np
import matplotlib.pyplot as plt
from sklearn.datasets import make_moons
from sklearn.model_selection import train_test_split
 
# ── Reproducibility ────────────────────────────────────────────────────────────
# Fix random seeds so every run produces identical weights, data splits,
# and results. Remove these lines only if you want stochastic variation.
torch.manual_seed(42)
np.random.seed(42)
 
# ── Hyperparameters ────────────────────────────────────────────────────────────
HIDDEN = 32       # Number of hidden units per layer
EPOCHS = 300      # Training iterations over the full dataset
LR     = 0.01     # Base learning rate passed to Adam
 
 
# ==============================================================================
# Neuron families
# ==============================================================================
 
class StandardNeuron(nn.Module):
    """
    A conventional neuron: linear projection followed by a ReLU activation.
 
    Computes:
        output = ReLU(x @ W^T + b)
 
    This is the default building block in most modern neural networks.
    It is included here as the baseline neuron type inside the heterogeneous layer.
 
    Args:
        in_features  (int): Dimensionality of the input vector.
        out_features (int): Number of neurons (output dimensionality).
    """
 
    def __init__(self, in_features: int, out_features: int):
        super().__init__()
        self.linear = nn.Linear(in_features, out_features)
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return F.relu(self.linear(x))
 
 
class PolynomialNeuron(nn.Module):
    """
    A quadratic (polynomial) neuron based on the formulation of Fan et al.
 
    Instead of a simple weighted sum, this neuron computes pairwise feature
    interactions, allowing it to model relationships like x_i * x_j directly.
    This pushes nonlinearity *inside* the neuron rather than applying it only
    at the activation stage.
 
    Computes:
        output = (x @ W_r^T) * (x @ W_g^T) + (x^2) @ W_b^T
 
    Where:
        W_r, W_g  capture multiplicative feature interactions (the quadratic term)
        W_b       captures element-wise squared input contributions
 
    Parameter cost is O(3n) — three times a standard neuron — but representational
    capacity is strictly higher. By the fundamental theorem of algebra, quadratic
    neurons are sufficient building blocks for polynomial function approximation.
 
    Args:
        in_features  (int): Dimensionality of the input vector.
        out_features (int): Number of neurons (output dimensionality).
    """
 
    def __init__(self, in_features: int, out_features: int):
        super().__init__()
        self.linear_r = nn.Linear(in_features, out_features)  # first interaction branch
        self.linear_g = nn.Linear(in_features, out_features)  # second interaction branch
        self.linear_b = nn.Linear(in_features, out_features)  # squared-input branch
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        # Multiply the two linear projections to get interaction terms,
        # then add the contribution from squared inputs
        return self.linear_r(x) * self.linear_g(x) + self.linear_b(x * x)
 
 
class DendriticNeuron(nn.Module):
    """
    A multi-branch dendritic neuron inspired by the two-stage computation of
    biological neurons.
 
    Real dendrites are not passive wires — local patches of the dendritic tree
    compute nonlinear functions of nearby synapses before the results reach the
    cell body (soma). This module models that by running several independent
    linear branches, applying a local tanh nonlinearity to each, and summing
    the results (soma integration).
 
    A single dendritic neuron can specialize different branches for different
    input patterns, supporting richer per-neuron computation than a point neuron.
 
    Computes (for B branches):
        output = sum_b( tanh(x @ W_b^T + bias_b) )  for b in 1..B
 
    Args:
        in_features  (int): Dimensionality of the input vector.
        out_features (int): Number of output units.
        branches     (int): Number of dendritic branches. Default: 3.
    """
 
    def __init__(self, in_features: int, out_features: int, branches: int = 3):
        super().__init__()
        # Each branch is an independent linear projection
        self.branches = nn.ModuleList([
            nn.Linear(in_features, out_features) for _ in range(branches)
        ])
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        # Accumulate branch outputs into a zero-initialised buffer
        out = torch.zeros(x.size(0), self.branches[0].out_features, device=x.device)
        for branch in self.branches:
            # tanh provides the local nonlinearity at each dendritic branch
            out = out + torch.tanh(branch(x))
        return out  # soma integration: sum of all branch activations
 
 
class SpikingNeuron(nn.Module):
    """
    A differentiable leaky integrate-and-fire (LIF) spiking neuron.
 
    Biological neurons communicate through discrete voltage spikes rather than
    continuous values. The LIF model captures this with three dynamics:
        1. Integration  — input current charges a membrane potential
        2. Leakage      — the potential decays over time toward zero
        3. Firing       — when the potential exceeds a threshold, a spike is emitted
                          and the potential partially resets
 
    Because the true spike (a hard threshold step) has zero gradient almost
    everywhere, training via backpropagation is impossible directly. We use a
    *surrogate gradient*: during the forward pass the sigmoid approximates the
    spike; during the backward pass its smooth gradient flows through normally.
 
    The neuron is simulated for `time_steps` steps; the output is the average
    spike rate, converting the temporal spike train into a single continuous value
    compatible with standard layers downstream.
 
    Computes over T time steps:
        I         = x @ W^T + b          (input current, fixed across steps)
        mem_t     = decay * mem_{t-1} + I (leaky integration)
        spike_t   = sigmoid(beta * (mem_t - threshold))  (surrogate spike)
        mem_t     = mem_t * (1 - spike_t)                (soft reset)
        output    = mean(spike_t)  over t = 1..T
 
    Args:
        in_features  (int):   Dimensionality of the input vector.
        out_features (int):   Number of output units.
        threshold    (float): Membrane potential required to trigger a spike. Default: 1.0.
        decay        (float): Fraction of membrane potential retained each step (leak). Default: 0.9.
        time_steps   (int):   Number of simulation steps per forward pass. Default: 10.
        beta         (float): Sharpness of the surrogate sigmoid; higher = closer to a true spike. Default: 10.0.
    """
 
    def __init__(
        self,
        in_features:  int,
        out_features: int,
        threshold:    float = 1.0,
        decay:        float = 0.9,
        time_steps:   int   = 10,
        beta:         float = 10.0,
    ):
        super().__init__()
        self.fc         = nn.Linear(in_features, out_features)
        self.threshold  = threshold
        self.decay      = decay
        self.time_steps = time_steps
        self.beta       = beta
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        I         = self.fc(x)                   # input current (constant across time)
        mem       = torch.zeros_like(I)           # membrane potential initialised to 0
        spike_sum = torch.zeros_like(I)           # accumulates spikes across time steps
 
        for _ in range(self.time_steps):
            mem       = self.decay * mem + I                            # leak + integrate
            spike     = torch.sigmoid(self.beta * (mem - self.threshold))  # surrogate spike
            mem       = mem * (1.0 - spike)                             # soft reset on fire
            spike_sum = spike_sum + spike
 
        # Return mean spike rate over the simulation window
        return spike_sum / self.time_steps
 
 
# ==============================================================================
# Network architectures
# ==============================================================================
 
class HeterogeneousLayer(nn.Module):
    """
    A single hidden layer that splits its units across all four neuron families.
 
    The layer divides `out_features` units as evenly as possible among:
        - StandardNeuron   (1/4 of units)
        - PolynomialNeuron (1/4 of units)
        - DendriticNeuron  (1/4 of units)
        - SpikingNeuron    (remaining units, absorbs any rounding remainder)
 
    Each family receives the full input independently. Their outputs are
    concatenated along the feature dimension, then passed through LayerNorm
    and a ReLU to produce a stable, normalised representation.
 
    This design lets each neuron type contribute its speciality:
        Standard   → fast, reliable baseline features
        Polynomial → feature interaction terms
        Dendritic  → multi-pattern specialisation
        Spiking    → sparse, temporally-averaged signals
 
    Args:
        in_features  (int): Dimensionality of the input vector.
        out_features (int): Total number of output units across all families.
                            Should be divisible by 4 for even splits.
    """
 
    def __init__(self, in_features: int, out_features: int):
        super().__init__()
        per = out_features // 4           # units per family (floor division)
        rem = out_features - 3 * per      # spiking gets any leftover units
 
        self.standard  = StandardNeuron(in_features, per)
        self.poly      = PolynomialNeuron(in_features, per)
        self.dendritic = DendriticNeuron(in_features, per)
        self.spiking   = SpikingNeuron(in_features, rem)
 
        # LayerNorm stabilises training when concatenating outputs of
        # very different magnitude (e.g. spiking rates vs polynomial products)
        self.norm = nn.LayerNorm(out_features)
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        # Run all four families on the same input and concatenate their outputs
        combined = torch.cat([
            self.standard(x),
            self.poly(x),
            self.dendritic(x),
            self.spiking(x),
        ], dim=1)
        # Normalise then apply ReLU to produce the final layer output
        return F.relu(self.norm(combined))
 
 
class StandardNet(nn.Module):
    """
    Baseline network composed entirely of standard ReLU neurons.
 
    Architecture:
        Linear(input_dim → hidden_dim) → LayerNorm → ReLU
        Linear(hidden_dim → hidden_dim) → LayerNorm → ReLU
        Linear(hidden_dim → output_dim)   [logits, no activation]
 
    LayerNorm is included to match the normalisation used in HeterogeneousNet,
    ensuring the comparison is as controlled as possible.
 
    Args:
        input_dim  (int): Number of input features.
        hidden_dim (int): Width of each hidden layer.
        output_dim (int): Number of output classes.
    """
 
    def __init__(self, input_dim: int, hidden_dim: int, output_dim: int):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, output_dim),  # raw logits for CrossEntropyLoss
        )
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.net(x)
 
 
class HeterogeneousNet(nn.Module):
    """
    Network composed of two HeterogeneousLayer hidden layers followed by a
    standard linear output layer.
 
    Architecture:
        HeterogeneousLayer(input_dim → hidden_dim)
        HeterogeneousLayer(hidden_dim → hidden_dim)
        Linear(hidden_dim → output_dim)   [logits, no activation]
 
    Note on parameter count:
        Because PolynomialNeuron uses 3× weights and DendriticNeuron uses
        branches× weights per unit, this network has more parameters than
        StandardNet at the same hidden_dim. See count_params() for exact figures.
 
    Args:
        input_dim  (int): Number of input features.
        hidden_dim (int): Total hidden units per HeterogeneousLayer.
        output_dim (int): Number of output classes.
    """
 
    def __init__(self, input_dim: int, hidden_dim: int, output_dim: int):
        super().__init__()
        self.layer1 = HeterogeneousLayer(input_dim, hidden_dim)
        self.layer2 = HeterogeneousLayer(hidden_dim, hidden_dim)
        self.final  = nn.Linear(hidden_dim, output_dim)
 
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x = self.layer1(x)
        x = self.layer2(x)
        return self.final(x)
 
 
# ==============================================================================
# Training and evaluation utilities
# ==============================================================================
 
def train_model(
    model:    nn.Module,
    X_train:  torch.Tensor,
    y_train:  torch.Tensor,
    X_test:   torch.Tensor,
    y_test:   torch.Tensor,
    epochs:   int   = EPOCHS,
    lr:       float = LR,
) -> tuple[list[float], list[float]]:
    """
    Train a model with Adam and cross-entropy loss, recording per-epoch metrics.
 
    At each epoch:
        1. Forward pass on the full training set
        2. Compute cross-entropy loss
        3. Backpropagate gradients and update weights (Adam step)
        4. Evaluate accuracy on the held-out test set (no gradient tracking)
 
    Args:
        model   (nn.Module):     The network to train.
        X_train (torch.Tensor):  Training features, shape (N_train, D).
        y_train (torch.Tensor):  Training labels,  shape (N_train,).
        X_test  (torch.Tensor):  Test features,    shape (N_test, D).
        y_test  (torch.Tensor):  Test labels,      shape (N_test,).
        epochs  (int):           Number of full passes over the training data.
        lr      (float):         Adam base learning rate.
 
    Returns:
        train_losses (list[float]): Cross-entropy loss at each epoch.
        test_accs    (list[float]): Fraction of test examples correctly classified
                                    at each epoch.
    """
    optimizer    = torch.optim.Adam(model.parameters(), lr=lr)
    loss_fn      = nn.CrossEntropyLoss()
    train_losses = []
    test_accs    = []
 
    for epoch in range(epochs):
        # ── Training step ──────────────────────────────────────────────────────
        model.train()
        optimizer.zero_grad()
        logits = model(X_train)
        loss   = loss_fn(logits, y_train)
        loss.backward()
        optimizer.step()
        train_losses.append(loss.item())
 
        # ── Evaluation step ────────────────────────────────────────────────────
        model.eval()
        with torch.no_grad():
            # argmax over class logits gives the predicted class index
            preds = model(X_test).argmax(dim=1)
            acc   = (preds == y_test).float().mean().item()
        test_accs.append(acc)
 
    return train_losses, test_accs
 
 
def count_params(model: nn.Module) -> int:
    """
    Count the total number of trainable parameters in a model.
 
    A parameter is any tensor that receives gradient updates during training
    (weights and biases). This count is useful for comparing model capacity
    across architectures.
 
    Args:
        model (nn.Module): Any PyTorch model.
 
    Returns:
        int: Total number of trainable scalar parameters.
    """
    return sum(p.numel() for p in model.parameters() if p.requires_grad)
 
 
def plot_decision_boundary(
    model: nn.Module,
    X:     np.ndarray,
    y:     np.ndarray,
    ax:    plt.Axes,
    title: str,
) -> None:
    """
    Visualise what region of 2D input space the model assigns to each class.
 
    A dense grid of points covering the data range is passed through the model.
    The predicted class at each grid point is used to colour the background,
    showing the decision boundary — the line where the model switches its
    prediction from one class to the other.
 
    Args:
        model (nn.Module):  A trained model that accepts (N, 2) float tensors.
        X     (np.ndarray): All data points, shape (N, 2). Used for axis limits
                            and scatter plot overlay.
        y     (np.ndarray): True class labels, shape (N,). Used for scatter colours.
        ax    (plt.Axes):   Matplotlib axes to draw on.
        title (str):        Title displayed above the plot.
    """
    # Build a grid that covers the full data range with a small margin
    x_min, x_max = X[:, 0].min() - 0.5, X[:, 0].max() + 0.5
    y_min, y_max = X[:, 1].min() - 0.5, X[:, 1].max() + 0.5
    xx, yy = np.meshgrid(
        np.linspace(x_min, x_max, 200),
        np.linspace(y_min, y_max, 200),
    )
 
    # Flatten the grid into (N_grid, 2) and get class predictions
    grid = torch.FloatTensor(np.c_[xx.ravel(), yy.ravel()])
    model.eval()
    with torch.no_grad():
        Z = model(grid).argmax(dim=1).numpy().reshape(xx.shape)
 
    # Filled contour shows predicted class regions; scatter shows true labels
    ax.contourf(xx, yy, Z, alpha=0.35, cmap='RdBu')
    ax.scatter(X[:, 0], X[:, 1], c=y, cmap='RdBu', edgecolor='k', s=18)
    ax.set_title(title)
    ax.set_xticks([])
    ax.set_yticks([])
 
 
# ==============================================================================
# Experiment
# ==============================================================================
 
# ── Dataset ────────────────────────────────────────────────────────────────────
# Two moons: 1000 points arranged in two interleaved crescents.
# noise=0.20 adds Gaussian jitter to make the boundary non-trivial.
X, y = make_moons(n_samples=1000, noise=0.20, random_state=42)
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)
 
# Convert numpy arrays to PyTorch tensors for training
X_train_t = torch.FloatTensor(X_train)
y_train_t  = torch.LongTensor(y_train)
X_test_t   = torch.FloatTensor(X_test)
y_test_t   = torch.LongTensor(y_test)
 
# ── Model instantiation ────────────────────────────────────────────────────────
print("Training Standard Net (ReLU only)...")
std_net  = StandardNet(input_dim=2, hidden_dim=HIDDEN, output_dim=2)
std_loss, std_acc = train_model(std_net, X_train_t, y_train_t, X_test_t, y_test_t)
 
print("Training Heterogeneous Net (standard + polynomial + dendritic + spiking)...")
het_net  = HeterogeneousNet(input_dim=2, hidden_dim=HIDDEN, output_dim=2)
het_loss, het_acc = train_model(het_net, X_train_t, y_train_t, X_test_t, y_test_t)
 
# ── Results summary ────────────────────────────────────────────────────────────
# Note: the two models have different parameter counts because polynomial and
# dendritic neurons require more weights per unit than standard neurons.
# A fair capacity-controlled comparison would match parameter counts by
# adjusting hidden_dim for the standard network.
n_std = count_params(std_net)
n_het = count_params(het_net)
 
print("\n" + "=" * 60)
print(f"{'Model':<20} {'Params':>10} {'Final Test Acc':>18}")
print("-" * 60)
print(f"{'Standard':<20} {n_std:>10,} {std_acc[-1]:>17.3f}")
print(f"{'Heterogeneous':<20} {n_het:>10,} {het_acc[-1]:>17.3f}")
print("=" * 60)
 
# ── Training curves ────────────────────────────────────────────────────────────
fig, axes = plt.subplots(1, 2, figsize=(11, 4))
 
axes[0].plot(std_loss, label='Standard',      lw=2)
axes[0].plot(het_loss, label='Heterogeneous', lw=2)
axes[0].set_xlabel('Epoch')
axes[0].set_ylabel('Training loss')
axes[0].set_title('Training Loss')
axes[0].legend()
axes[0].grid(alpha=0.3)
 
axes[1].plot(std_acc, label='Standard',      lw=2)
axes[1].plot(het_acc, label='Heterogeneous', lw=2)
axes[1].set_xlabel('Epoch')
axes[1].set_ylabel('Test accuracy')
axes[1].set_title('Test Accuracy')
axes[1].legend()
axes[1].grid(alpha=0.3)
 
plt.tight_layout()
plt.show()
 
# ── Decision boundaries ────────────────────────────────────────────────────────
fig2, axes2 = plt.subplots(1, 2, figsize=(11, 5))
plot_decision_boundary(
    std_net, X, y, axes2[0],
    f'Standard NN  (test acc = {std_acc[-1]:.3f})'
)
plot_decision_boundary(
    het_net, X, y, axes2[1],
    f'Heterogeneous NN (test acc = {het_acc[-1]:.3f})'
)
plt.tight_layout()
plt.show()
